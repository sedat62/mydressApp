rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Products - anyone can read, only admins can write
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Categories - anyone can read, only admins can write
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Users - owner can read own doc, admins can read/write all
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Yeni kayıt: sadece kendi UID'si ve role alanı 'user' olabilir (admin yükseltmesi engellenir)
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.role == 'user';
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Generations - owner can CRUD own, admins can read all
    match /generations/{generationId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Social posts - anyone can read, authenticated can create/update, admins can moderate
    match /social_posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Subscriptions - owner can read own, admins can read/write all
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }
  }
}
